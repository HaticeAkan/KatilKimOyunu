<Window x:Class="KatilKimOyunu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Katil Kim?" Height="450" Width="800">

    <Grid>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="KATİL KİM?"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Button Name="btnYeniOyun"
                    Content="Yeni Oyun"
                    Width="200"
                    Height="50"
                    Margin="0,10"
                    Background="DarkRed"
                    FontWeight="Bold"
                    Click="btnYeniOyun_Click"/>

            <Button Name="btnCikis"
                    
                    Content="Çıkış"
                    Width="200"
                    Height="50"
                    Margin="0,10"
                    Background="DarkRed"
                    FontWeight="Bold"
                    Click="btnCikis_Click"/>
            <TextBlock
            FontSize="40"
FontWeight="Bold"
Foreground="White"/>

        </StackPanel>

    </Grid>

</Window>